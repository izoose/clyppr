<Window x:Class="Clipper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        Title="Clipper" Height="760" Width="1200" MinHeight="520" MinWidth="880"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <local:PathToImageConverter x:Key="Thumb"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource Sidebar}">
            <StackPanel>
                <TextBlock Text="◆" Foreground="{StaticResource Accent}" FontSize="22"
                           HorizontalAlignment="Center" Margin="0,14,0,16"/>
                <Button Style="{StaticResource IconButton}" Content="&#xE8A9;" ToolTip="Library"/>
                <Button Style="{StaticResource IconButton}" Content="&#xE713;" ToolTip="Settings"
                        Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource TopBar}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Margin="14,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9" Margin="2,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextFaint}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BufferRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Good}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ManualRecording}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Rec}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" FontSize="13"/>

                        <Border Width="1" Background="{StaticResource Border}" Margin="14,4"/>

                        <Button Style="{StaticResource AccentButton}" Command="{Binding ClipNowCommand}" ToolTip="Save the last few seconds (ALT+C)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Clip"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource BarButton}" Command="{Binding ToggleBufferCommand}" Margin="6,0,0,0">
                            <TextBlock Text="{Binding BufferRunning, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='Buffer On|Buffer Off'}"/>
                        </Button>
                        <Button Style="{StaticResource BarButton}" Command="{Binding ToggleRecordCommand}">
                            <TextBlock Text="{Binding ManualRecording, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='Stop Rec|Record'}"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Grid Width="230" Margin="0,0,10,0">
                            <TextBox Style="{StaticResource SearchBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
                            <TextBlock Text="Search clips" Foreground="{StaticResource TextFaint}" IsHitTestVisible="False"
                                       Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Style="{StaticResource BarButton}" Command="{Binding ImportCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0"/>
                                <TextBlock Text="Import"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Clip grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,6,14">
                <ItemsControl ItemsSource="{Binding Clips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" Margin="0,0,14,14" Background="{StaticResource Card}" CornerRadius="12"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <StackPanel>
                                    <!-- Thumbnail -->
                                    <Grid Height="169">
                                        <Border CornerRadius="12,12,0,0" ClipToBounds="True">
                                            <Grid>
                                                <Rectangle Fill="#0A0A0D"/>
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource Thumb}}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <Border Background="#B0000000" CornerRadius="5" Padding="6,2" Margin="0,0,8,8"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding DurationText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <!-- Info -->
                                    <StackPanel Margin="12,10,12,12">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="14"
                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                            <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="12"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='MMM d'}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                        </StackPanel>

                                        <ItemsControl ItemsSource="{Binding TrackList}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource Chip}">
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Actions -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Style="{StaticResource CardButton}" Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                                    ToolTip="Play"
                                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource CardButton}" Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0"
                                                    ToolTip="Edit" AutomationProperties.AutomationId="EditBtn"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource CardButton}" Margin="6,0,0,0" ToolTip="Copy share link"
                                                    Command="{Binding DataContext.ShareCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Copy Link" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource CardButton}" Content="&#xE712;" FontFamily="Segoe MDL2 Assets"
                                                    Margin="6,0,0,0" ToolTip="More" Click="MoreButton_Click"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Open file location"
                                                                  Command="{Binding PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="Copy file path"
                                                                  Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator/>
                                                        <MenuItem Header="Delete"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding Clips.Count, Converter={x:Static local:CountToVisibilityConverter.ZeroVisible}}">
                <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{StaticResource TextFaint}" HorizontalAlignment="Center"/>
                <TextBlock Text="No clips yet" Foreground="{StaticResource TextDim}" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,2"/>
                <TextBlock Text="Press ALT+C in game, or Import a video." Foreground="{StaticResource TextFaint}" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Toast -->
            <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,22"
                    Background="#2A2A33" CornerRadius="10" Padding="16,10"
                    Visibility="{Binding Toast, Converter={x:Static local:NotEmptyToVisibilityConverter.Instance}}">
                <TextBlock Text="{Binding Toast}" Foreground="{StaticResource Text}" FontSize="13"/>
            </Border>
        </Grid>
    </Grid>
</Window>
