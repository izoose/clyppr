<Window x:Class="Clipper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Clipper" Height="760" Width="1200" MinHeight="520" MinWidth="900"
        Icon="pack://application:,,,/Assets/clipper.png"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Grayscale">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:PathToImageConverter x:Key="Thumb"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== Custom title bar ===== -->
            <Grid Grid.Row="0" Background="{StaticResource TopBar}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Image Source="pack://application:,,,/Assets/clipper.png" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Clipper" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <Border Width="1" Background="{StaticResource Border}" Margin="14,10"/>
                    <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource TextFaint}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BufferRunning}" Value="True"><Setter Property="Fill" Value="{StaticResource Good}"/></DataTrigger>
                                    <DataTrigger Binding="{Binding ManualRecording}" Value="True"><Setter Property="Fill" Value="{StaticResource Rec}"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" FontSize="12"/>

                    <Button Style="{StaticResource AccentButton}" Command="{Binding ClipNowCommand}" Margin="14,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Save the last few seconds (ALT+C)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,7,0"/>
                            <TextBlock Text="Clip"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BarButton}" Command="{Binding ToggleBufferCommand}" Margin="6,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{Binding BufferRunning, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='Buffer On|Buffer Off'}"/>
                    </Button>
                    <Button Style="{StaticResource BarButton}" Command="{Binding ToggleRecordCommand}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{Binding ManualRecording, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='Stop Rec|Record'}"/>
                    </Button>
                </StackPanel>

                <!-- Window buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Style="{StaticResource WindowButton}" Content="&#xE921;" Click="Min_Click"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource WindowButton}" Content="&#xE922;" Click="Max_Click"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===== Body ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="56"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource Sidebar}">
                    <StackPanel Margin="0,8,0,0">
                        <Button Style="{StaticResource NavButton}" Content="&#xE8A9;" ToolTip="Library" Command="{Binding ShowLibraryCommand}"
                                Tag="{Binding ShowSettings, Converter={x:Static local:ActiveTagConverter.WhenFalse}}"/>
                        <Button Style="{StaticResource NavButton}" Content="&#xE713;" ToolTip="Settings" Command="{Binding OpenSettingsCommand}"
                                AutomationProperties.AutomationId="SettingsBtn"
                                Tag="{Binding ShowSettings, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                    </StackPanel>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1">
                    <!-- Library -->
                    <Grid Visibility="{Binding ShowSettings, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,12,14,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Grid Width="240" Margin="0,0,10,0">
                                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
                                    <TextBlock Text="Search clips" Foreground="{StaticResource TextFaint}" IsHitTestVisible="False"
                                               Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Button Style="{StaticResource BarButton}" Command="{Binding ImportCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0"/>
                                        <TextBlock Text="Import"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Albums filter row -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="18,0,14,12">
                            <Button Style="{StaticResource Pill}" Content="All Clips" Command="{Binding SelectAllCommand}"
                                    Tag="{Binding AllSelected, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                            <ItemsControl ItemsSource="{Binding Albums}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource Pill}" Content="{Binding Name}" MouseRightButtonUp="AlbumChip_RightClick"
                                                Command="{Binding DataContext.SelectAlbumCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Tag="{Binding IsSelected, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource BarButton}" Content="+ New album" Command="{Binding NewAlbumCommand}" FontSize="12" Padding="10,6"
                                    AutomationProperties.AutomationId="NewAlbumBtn"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="18,4,8,14">
                            <ItemsControl ItemsSource="{Binding Clips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="340" Margin="0,0,16,16" Background="{StaticResource Card}" CornerRadius="12" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#3A3A44"/>
                                                            <Setter Property="Background" Value="{StaticResource CardHover}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid Height="191">
                                                    <Border CornerRadius="11,11,0,0" ClipToBounds="True">
                                                        <Grid>
                                                            <Rectangle Fill="#08080A"/>
                                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource Thumb}}" Stretch="UniformToFill"/>
                                                        </Grid>
                                                    </Border>
                                                    <Border Background="#B0000000" CornerRadius="5" Padding="6,2" Margin="0,0,8,8"
                                                            HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                                        <TextBlock Text="{Binding DurationText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                                <StackPanel Margin="12,10,12,12">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="14"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                                        <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="12"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat='MMM d'}" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding TrackList}" Margin="0,8,0,0">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource Chip}">
                                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextDim}" FontSize="10"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <Button Style="{StaticResource CardButton}" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" ToolTip="Play"
                                                                Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                        <Button Style="{StaticResource CardButton}" Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" ToolTip="Edit"
                                                                AutomationProperties.AutomationId="EditBtn"
                                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                        <Button Style="{StaticResource CardButton}" Margin="6,0,0,0" ToolTip="Copy share link"
                                                                AutomationProperties.AutomationId="ShareBtn"
                                                                Command="{Binding DataContext.ShareCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                                                <TextBlock Text="Copy Link" FontSize="12"/>
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource CardButton}" Content="&#xE712;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" ToolTip="More"
                                                                AutomationProperties.AutomationId="MoreBtn" Click="MoreButton_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding Clips.Count, Converter={x:Static local:CountToVisibilityConverter.ZeroVisible}}">
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{StaticResource TextFaint}" HorizontalAlignment="Center"/>
                            <TextBlock Text="No clips yet" Foreground="{StaticResource TextDim}" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,2"/>
                            <TextBlock Text="Press ALT+C in game, or Import a video." Foreground="{StaticResource TextFaint}" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Settings tab -->
                    <local:SettingsView DataContext="{Binding CurrentSettings}"
                                        Visibility="{Binding DataContext.ShowSettings, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>

                    <!-- Toast -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,22"
                            Background="#26262C" CornerRadius="10" Padding="16,10"
                            Visibility="{Binding Toast, Converter={x:Static local:NotEmptyToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding Toast}" Foreground="{StaticResource Text}" FontSize="13"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
