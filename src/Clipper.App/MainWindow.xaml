<Window x:Class="Clipper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Clipper" Height="820" Width="1440" MinHeight="560" MinWidth="1000"
        Icon="pack://application:,,,/Assets/clipper.png"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}"
        WindowStyle="None" ResizeMode="CanResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Grayscale">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:PathToImageConverter x:Key="Thumb"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===================== TITLE BAR ===================== -->
            <Grid Grid.Row="0" Background="#0C0C0F">
                <!-- Left: logo + now clipping -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <Image Source="pack://application:,,,/Assets/clipper.png" Width="28" Height="28" VerticalAlignment="Center"/>
                    <Border Width="1" Background="{StaticResource Border}" Margin="14,14"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Now Clipping" Foreground="{StaticResource TextFaint}" FontSize="10"/>
                        <TextBlock Text="{Binding NowGame}" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: capture controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Style="{StaticResource CaptureBtn}" Command="{Binding ClipNowCommand}" ToolTip="Save the last clip"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource KeyBadge}"><TextBlock Text="ALT" Foreground="{StaticResource TextDim}" FontSize="10"/></Border>
                            <Border Style="{StaticResource KeyBadge}"><TextBlock Text="{Binding HotkeyKeyDisplay}" Foreground="{StaticResource TextDim}" FontSize="10"/></Border>
                            <TextBlock Text="{Binding ClipMinutes, StringFormat='Clip {0}m'}" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{StaticResource Border}" Margin="8,14"/>
                    <Button Style="{StaticResource CaptureBtn}" Command="{Binding ToggleRecordCommand}" ToolTip="Long recording"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource KeyBadge}"><TextBlock Text="ALT" Foreground="{StaticResource TextDim}" FontSize="10"/></Border>
                            <Border Style="{StaticResource KeyBadge}"><TextBlock Text="F7" Foreground="{StaticResource TextDim}" FontSize="10"/></Border>
                            <TextBlock Text="{Binding ManualRecording, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='Stop Recording|Long Recording'}" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{StaticResource Border}" Margin="8,14"/>
                    <Button Style="{StaticResource CaptureBtn}" Command="{Binding ToggleBufferCommand}" ToolTip="Always-on replay buffer"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Auto Clip" Foreground="{StaticResource Text}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding BufferRunning, Converter={x:Static local:BoolTextConverter.OnOff}, ConverterParameter='ON|OFF'}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Margin="7,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BufferRunning}" Value="True"><Setter Property="Foreground" Value="{StaticResource Good}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: window buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Style="{StaticResource WindowButton}" Content="&#xE921;" Click="Min_Click"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource WindowButton}" Content="&#xE922;" Click="Max_Click"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===================== TOOLBAR ===================== -->
            <Border Grid.Row="1" Background="#141419" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Margin="12,0,14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource BarButton}" Command="{Binding ImportCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Import" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource BarButton}" Command="{Binding OpenMontageCommand}" AutomationProperties.AutomationId="MontageBtn" ToolTip="Stitch clips">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B2;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="New Edit" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource BarButton}" Command="{Binding ToggleFavoritesFilterCommand}" ToolTip="Favorites">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Filters" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ClipCount, StringFormat='{}{0} Clips'}" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <Border Width="1" Background="{StaticResource Border}" Margin="0,10,14,10"/>
                        <Grid Width="230">
                            <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
                            <TextBlock Text="Search" Foreground="{StaticResource TextFaint}" IsHitTestVisible="False" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=SearchBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocused, ElementName=SearchBox}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== BODY ===================== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource Sidebar}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                            <Button Style="{StaticResource NavButton}" Content="&#xE713;" ToolTip="Settings" Command="{Binding OpenSettingsCommand}"
                                    AutomationProperties.AutomationId="SettingsBtn"
                                    Tag="{Binding ShowSettings, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0">
                            <Button Style="{StaticResource NavButton}" Content="&#xE80F;" ToolTip="Home" Command="{Binding ShowLibraryCommand}"/>
                            <Button Style="{StaticResource NavButton}" Content="&#xE8A9;" ToolTip="Library" Command="{Binding ShowLibraryCommand}"
                                    Tag="{Binding ShowSettings, Converter={x:Static local:ActiveTagConverter.WhenFalse}}"/>
                            <Button Style="{StaticResource NavButton}" Content="&#xE7FC;" ToolTip="Games"/>
                            <Button Style="{StaticResource NavButton}" Content="&#xE734;" ToolTip="Favorites" Command="{Binding ToggleFavoritesFilterCommand}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1">
                    <!-- Library -->
                    <Grid Visibility="{Binding ShowSettings, Converter={x:Static local:InverseBoolToVisibilityConverter.Instance}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Albums row -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,14,14,12">
                            <Button Style="{StaticResource Pill}" Content="All Clips" Command="{Binding SelectAllCommand}"
                                    Tag="{Binding AllSelected, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                            <Button Style="{StaticResource Pill}" ToolTip="Favorites only" Command="{Binding ToggleFavoritesFilterCommand}"
                                    Tag="{Binding FavoritesOnly, Converter={x:Static local:ActiveTagConverter.WhenTrue}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ItemsControl ItemsSource="{Binding Albums}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource Pill}" Content="{Binding Name}" MouseRightButtonUp="AlbumChip_RightClick"
                                                Command="{Binding DataContext.SelectAlbumCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Tag="{Binding IsSelected, Converter={x:Static local:ActiveTagConverter.WhenTrue}}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource BarButton}" Content="+ New album" Command="{Binding NewAlbumCommand}" FontSize="12" Padding="10,6"
                                    AutomationProperties.AutomationId="NewAlbumBtn"/>
                        </StackPanel>

                        <!-- Clip grid -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,2,10,14">
                            <ItemsControl ItemsSource="{Binding Clips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="262" Margin="0,0,10,10" Background="{StaticResource Card}" CornerRadius="7" BorderThickness="1"
                                                MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="#3A3A44"/></Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Thumbnail -->
                                                <Grid Height="147" Cursor="Hand" Background="Transparent" MouseLeftButtonUp="Thumb_Click">
                                                    <Border CornerRadius="7,7,0,0" ClipToBounds="True">
                                                        <Grid>
                                                            <Rectangle Fill="#08080A"/>
                                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource Thumb}}" Stretch="UniformToFill"/>
                                                            <MediaElement x:Name="Preview" Stretch="UniformToFill" LoadedBehavior="Manual" Volume="0" Visibility="Collapsed" IsMuted="True" IsHitTestVisible="False"/>
                                                        </Grid>
                                                    </Border>
                                                    <!-- hover overlay -->
                                                    <Grid>
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Opacity" Value="0"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Rectangle Fill="#40000000" IsHitTestVisible="False"/>
                                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Opacity="0.9"/>
                                                        <Button Style="{StaticResource FavButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6" ToolTip="Favorite"
                                                                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                        <Button Style="{StaticResource CardButton}" Content="&#xE712;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                                                                ToolTip="More" AutomationProperties.AutomationId="MoreBtn" Click="MoreButton_Click"/>
                                                    </Grid>
                                                    <Border Background="#B0000000" CornerRadius="4" Padding="6,2" Margin="0,0,7,7" HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                                        <TextBlock Text="{Binding DurationText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                                <!-- Info -->
                                                <StackPanel Margin="10,8,10,7">
                                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource TextFaint}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="On Device" Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="11"/>
                                                        <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="11"/>
                                                        <TextBlock Text="{Binding TimeAgo}" Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Copy link bar -->
                                                <Border BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="8,6">
                                                    <Grid>
                                                        <Button Style="{StaticResource CardButton}" Background="Transparent" HorizontalAlignment="Left" AutomationProperties.AutomationId="ShareBtn"
                                                                Command="{Binding DataContext.ShareCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="Copy Link" FontSize="12" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Style="{StaticResource CardButton}" Background="Transparent" Content="&#xE898;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" ToolTip="Upload &amp; share"
                                                                Command="{Binding DataContext.ShareCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding Clips.Count, Converter={x:Static local:CountToVisibilityConverter.ZeroVisible}}">
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="{StaticResource TextFaint}" HorizontalAlignment="Center"/>
                            <TextBlock Text="No clips yet" Foreground="{StaticResource TextDim}" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,2"/>
                            <TextBlock Text="Press ALT+C in game, or Import a video." Foreground="{StaticResource TextFaint}" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Settings tab -->
                    <local:SettingsView DataContext="{Binding CurrentSettings}"
                                        Visibility="{Binding DataContext.ShowSettings, RelativeSource={RelativeSource AncestorType=Window}, Converter={x:Static local:BoolToVisibilityConverter.Instance}}"/>

                    <!-- Toast -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,22" Background="#26262C" CornerRadius="10" Padding="16,10"
                            Visibility="{Binding Toast, Converter={x:Static local:NotEmptyToVisibilityConverter.Instance}}">
                        <TextBlock Text="{Binding Toast}" Foreground="{StaticResource Text}" FontSize="13"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
