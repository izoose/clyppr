<UserControl x:Class="Clipper.App.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Clipper.App">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PanelTitle">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PanelDesc">
            <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SettingsNav" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Card}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left category nav -->
        <Border Grid.Column="0" Background="{StaticResource Sidebar}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <StackPanel Margin="12,18">
                <TextBlock Text="Settings" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="8,0,0,14"/>
                <Button Style="{StaticResource SettingsNav}" Content="Recording" Command="{Binding SelectSectionCommand}" CommandParameter="Recording"
                        Tag="{Binding Section, Converter={x:Static local:SectionActiveConverter.Instance}, ConverterParameter=Recording}"/>
                <Button Style="{StaticResource SettingsNav}" Content="Hotkeys" Command="{Binding SelectSectionCommand}" CommandParameter="Hotkeys"
                        Tag="{Binding Section, Converter={x:Static local:SectionActiveConverter.Instance}, ConverterParameter=Hotkeys}"/>
                <Button Style="{StaticResource SettingsNav}" Content="Storage" Command="{Binding SelectSectionCommand}" CommandParameter="Storage"
                        Tag="{Binding Section, Converter={x:Static local:SectionActiveConverter.Instance}, ConverterParameter=Storage}"/>
                <Button Style="{StaticResource SettingsNav}" Content="Sharing" Command="{Binding SelectSectionCommand}" CommandParameter="Sharing"
                        Tag="{Binding Section, Converter={x:Static local:SectionActiveConverter.Instance}, ConverterParameter=Sharing}"/>
                <Button Style="{StaticResource SettingsNav}" Content="Startup" Command="{Binding SelectSectionCommand}" CommandParameter="Startup"
                        Tag="{Binding Section, Converter={x:Static local:SectionActiveConverter.Instance}, ConverterParameter=Startup}"/>
            </StackPanel>
        </Border>

        <!-- Right panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,26,30,10">
                <Grid MaxWidth="600" HorizontalAlignment="Left">
                    <!-- Recording -->
                    <StackPanel Visibility="{Binding Section, Converter={x:Static local:SectionVisibleConverter.Instance}, ConverterParameter=Recording}">
                        <TextBlock Text="Recording" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Text="How Clipper captures your gameplay and audio." Style="{StaticResource PanelDesc}"/>
                        <TextBlock Text="Voice app to separate (process name, no .exe)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding VoiceApp}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Text="FPS" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding Fps}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Quality (CQ, lower = better)" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding Cq}"/></StackPanel>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Text="Buffer length (seconds)" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding BufferSeconds}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Clip length saved (seconds)" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding ClipLengthSeconds}"/></StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Hotkeys -->
                    <StackPanel Visibility="{Binding Section, Converter={x:Static local:SectionVisibleConverter.Instance}, ConverterParameter=Hotkeys}">
                        <TextBlock Text="Hotkeys" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Text="The global hotkey that saves a clip from the buffer." Style="{StaticResource PanelDesc}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Text="Modifiers (Alt / Control / Shift / Win)" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding HotkeyModifiers}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Key" Style="{StaticResource Label}"/><TextBox Style="{StaticResource SearchBox}" Text="{Binding HotkeyKey}"/></StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Storage -->
                    <StackPanel Visibility="{Binding Section, Converter={x:Static local:SectionVisibleConverter.Instance}, ConverterParameter=Storage}">
                        <TextBlock Text="Storage" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Text="Where clips are saved and whether recording starts automatically." Style="{StaticResource PanelDesc}"/>
                        <TextBlock Text="Clips folder" Style="{StaticResource Label}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Text="{Binding ClipsDirectory}"/>
                            <Button Grid.Column="1" Style="{StaticResource CardButton}" Content="Browse…" Margin="8,0,0,0" Command="{Binding BrowseClipsDirCommand}"/>
                        </Grid>
                        <CheckBox Content="Start the replay buffer when the app opens" IsChecked="{Binding BufferEnabledOnStart}" Foreground="{StaticResource Text}" Margin="0,16,0,0"/>
                    </StackPanel>

                    <!-- Sharing -->
                    <StackPanel Visibility="{Binding Section, Converter={x:Static local:SectionVisibleConverter.Instance}, ConverterParameter=Sharing}">
                        <TextBlock Text="Sharing" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Text="Your self-hosted share server. Copy Link uploads clips here." Style="{StaticResource PanelDesc}"/>
                        <TextBlock Text="Share server URL (e.g. https://clips.yourdomain.com)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding ShareEndpoint}"/>
                        <TextBlock Text="Upload token (must match the server's UPLOAD_TOKEN)" Style="{StaticResource Label}" Margin="0,12,0,4"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding ShareToken}"/>
                    </StackPanel>

                    <!-- Startup -->
                    <StackPanel Visibility="{Binding Section, Converter={x:Static local:SectionVisibleConverter.Instance}, ConverterParameter=Startup}">
                        <TextBlock Text="Startup" Style="{StaticResource PanelTitle}"/>
                        <TextBlock Text="Launch Clipper automatically with Windows." Style="{StaticResource PanelDesc}"/>
                        <CheckBox Content="Run Clipper when Windows starts (to tray)" IsChecked="{Binding RunOnStartup}" Foreground="{StaticResource Text}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Save bar -->
            <Border Grid.Row="1" Background="{StaticResource TopBar}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="30,12">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AccentButton}" Content="Save" Padding="26,9" Command="{Binding SaveCommand}"/>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource Good}" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
