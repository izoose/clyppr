<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette (Medal-like: near-black, subtle borders, restrained gold accent) -->
    <SolidColorBrush x:Key="Bg" Color="#0D0D0F"/>
    <SolidColorBrush x:Key="Sidebar" Color="#0A0A0C"/>
    <SolidColorBrush x:Key="TopBar" Color="#131316"/>
    <SolidColorBrush x:Key="Card" Color="#17171A"/>
    <SolidColorBrush x:Key="CardHover" Color="#1F1F23"/>
    <SolidColorBrush x:Key="Border" Color="#26262B"/>
    <SolidColorBrush x:Key="Text" Color="#E8E8EA"/>
    <SolidColorBrush x:Key="TextDim" Color="#93939C"/>
    <SolidColorBrush x:Key="TextFaint" Color="#62626C"/>
    <SolidColorBrush x:Key="Accent" Color="#E3B44A"/>
    <SolidColorBrush x:Key="AccentText" Color="#1A1608"/>
    <SolidColorBrush x:Key="Good" Color="#41B37F"/>
    <SolidColorBrush x:Key="Rec" Color="#E5534B"/>
    <SolidColorBrush x:Key="Hover" Color="#20FFFFFF"/>

    <!-- Window caption buttons (min / max) -->
    <Style x:Key="WindowButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Hover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Rec}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar nav icon -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextFaint}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="6,3">
                        <Border x:Name="active" Width="3" HorizontalAlignment="Left" CornerRadius="2"
                                Background="{StaticResource Accent}" Visibility="Collapsed"/>
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                        <Trigger Property="Tag" Value="active">
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                            <Setter TargetName="active" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Top-bar / general text button -->
    <Style x:Key="BarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent (primary) button -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource BarButton}">
        <Setter Property="Foreground" Value="{StaticResource AccentText}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{StaticResource Accent}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card action button -->
    <Style x:Key="CardButton" TargetType="Button" BasedOn="{StaticResource BarButton}">
        <Setter Property="Background" Value="#212127"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Search / text box -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="#1B1B20"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="#232329"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
    </Style>

</ResourceDictionary>
