<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette -->
    <Color x:Key="BgColor">#0E0E11</Color>
    <SolidColorBrush x:Key="Bg" Color="#0E0E11"/>
    <SolidColorBrush x:Key="Sidebar" Color="#17171C"/>
    <SolidColorBrush x:Key="TopBar" Color="#131318"/>
    <SolidColorBrush x:Key="Card" Color="#1B1B21"/>
    <SolidColorBrush x:Key="CardHover" Color="#23232B"/>
    <SolidColorBrush x:Key="Border" Color="#2A2A33"/>
    <SolidColorBrush x:Key="Text" Color="#E9E9EC"/>
    <SolidColorBrush x:Key="TextDim" Color="#9A9AA6"/>
    <SolidColorBrush x:Key="TextFaint" Color="#6C6C78"/>
    <SolidColorBrush x:Key="Accent" Color="#F0C24B"/>
    <SolidColorBrush x:Key="AccentText" Color="#1A1A10"/>
    <SolidColorBrush x:Key="Good" Color="#3FB27F"/>
    <SolidColorBrush x:Key="Rec" Color="#E5534B"/>

    <!-- Sidebar icon button -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="10" Margin="6,3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Top-bar / general text button -->
    <Style x:Key="BarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource CardHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent (primary) button -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource BarButton}">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentText}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card action button (subtle, bordered) -->
    <Style x:Key="CardButton" TargetType="Button" BasedOn="{StaticResource BarButton}">
        <Setter Property="Background" Value="#24242C"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Padding" Value="9,6"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Search / text box -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="#1E1E25"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="#26262F"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
    </Style>

</ResourceDictionary>
