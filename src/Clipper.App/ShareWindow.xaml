<Window x:Class="Clipper.App.ShareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Share" Height="620" Width="460" ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/clipper.png"
        Background="Transparent" WindowStartupLocation="CenterOwner" AllowsTransparency="True"
        FontFamily="{StaticResource AppFont}" WindowStyle="None"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Grayscale">

    <Border Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="14">
        <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.55" Color="#000000"/></Border.Effect>
        <Grid Margin="22,18,22,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock Text="Share clip" Foreground="{StaticResource Text}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Style="{StaticResource CardButton}" Background="Transparent" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource TextDim}" Click="Close_Click"/>
            </Grid>

            <!-- Draggable preview -->
            <Border Grid.Row="1" x:Name="DragCard" Margin="0,16,0,0" CornerRadius="10" ClipToBounds="True" Cursor="Hand"
                    Height="220" Background="#000000"
                    PreviewMouseLeftButtonDown="Drag_Down" PreviewMouseMove="Drag_Move"
                    ToolTip="Drag me into Discord, a DM, or your desktop">
                <Grid>
                    <Image x:Name="Thumb" Stretch="UniformToFill"/>
                    <Border Background="#B0000000" CornerRadius="5" Padding="7,3" Margin="0,0,10,10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <TextBlock x:Name="DurationText" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#CC000000" CornerRadius="7" Padding="10,6" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C2;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="Drag to share" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" x:Name="TitleText" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold" Margin="2,14,0,0" TextTrimming="CharacterEllipsis"/>

            <!-- Primary: copy the clip file (paste straight into Discord) -->
            <Button Grid.Row="3" Style="{StaticResource AccentButton}" Margin="0,14,0,0" Padding="12,11" Click="CopyFile_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Copy clip — paste into Discord" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Secondary actions -->
            <Grid Grid.Row="4" Margin="0,9,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="9"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource CardButton}" Padding="8,10" Click="OpenFolder_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource Text}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Show file" FontSize="11.5" Foreground="{StaticResource TextDim}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource CardButton}" Padding="8,10" Click="Export_Click" ToolTip="Save a copy somewhere else">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource Text}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Save as" FontSize="11.5" Foreground="{StaticResource TextDim}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Social -->
            <StackPanel Grid.Row="5" Margin="0,18,0,0">
                <TextBlock Text="SHARE TO" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SocialBtn}" Background="#000000" Click="X_Click" ToolTip="Share to X">
                        <Path Fill="White" Stretch="Uniform" Width="19" Height="19"
                              Data="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </Button>
                    <Button Style="{StaticResource SocialBtn}" Background="#FF4500" Click="Reddit_Click" ToolTip="Post to Reddit">
                        <Path Fill="White" Stretch="Uniform" Width="23" Height="23"
                              Data="F1 M17.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
                    </Button>
                    <Button Style="{StaticResource SocialBtn}" Background="#FF0000" Click="YouTube_Click" ToolTip="Upload to YouTube">
                        <Path Fill="White" Stretch="Uniform" Width="16" Height="16" Data="M9 7.5 L9 16.5 L16.5 12 Z"/>
                    </Button>
                    <Button Style="{StaticResource SocialBtn}" Background="#5865F2" Click="Discord_Click" ToolTip="Send on Discord">
                        <Path Fill="White" Stretch="Uniform" Width="21" Height="21"
                              Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="7" x:Name="StatusText" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Bottom" TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
