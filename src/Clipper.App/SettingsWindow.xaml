<Window x:Class="Clipper.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        Title="Settings" Height="680" Width="560" MinWidth="480"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterOwner" UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Section">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,18,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource TopBar}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="18,12">
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource Good}" VerticalAlignment="Center" FontSize="13"/>
                <Button Style="{StaticResource AccentButton}" Content="Save" Padding="24,8" HorizontalAlignment="Right"
                        Command="{Binding SaveCommand}"/>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,10,18,18">
                <TextBlock Text="RECORDING" Style="{StaticResource Section}"/>

                <TextBlock Text="Voice app to separate (process name, no .exe)" Style="{StaticResource Label}"/>
                <TextBox Style="{StaticResource SearchBox}" Text="{Binding VoiceApp}"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="FPS" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding Fps}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Quality (CQ, lower = better)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding Cq}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Buffer length (seconds)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding BufferSeconds}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Clip length saved (seconds)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding ClipLengthSeconds}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hotkey modifiers (Alt / Control / Shift / Win)" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding HotkeyModifiers}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hotkey key" Style="{StaticResource Label}"/>
                        <TextBox Style="{StaticResource SearchBox}" Text="{Binding HotkeyKey}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Clips folder" Style="{StaticResource Label}" Margin="0,10,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Text="{Binding ClipsDirectory}"/>
                    <Button Grid.Column="1" Style="{StaticResource CardButton}" Content="Browse…" Margin="8,0,0,0" Command="{Binding BrowseClipsDirCommand}"/>
                </Grid>

                <CheckBox Content="Start the replay buffer when the app opens" IsChecked="{Binding BufferEnabledOnStart}"
                          Foreground="{StaticResource Text}" Margin="0,14,0,0"/>

                <TextBlock Text="SHARING (your VPS)" Style="{StaticResource Section}"/>
                <TextBlock Text="Share server URL (e.g. https://clips.yourdomain.com)" Style="{StaticResource Label}"/>
                <TextBox Style="{StaticResource SearchBox}" Text="{Binding ShareEndpoint}"/>
                <TextBlock Text="Upload token (must match the server's UPLOAD_TOKEN)" Style="{StaticResource Label}" Margin="0,10,0,4"/>
                <TextBox Style="{StaticResource SearchBox}" Text="{Binding ShareToken}"/>

                <TextBlock Text="STARTUP" Style="{StaticResource Section}"/>
                <CheckBox Content="Run Clipper when Windows starts (to tray)" IsChecked="{Binding RunOnStartup}"
                          Foreground="{StaticResource Text}"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
