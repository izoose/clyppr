<Window x:Class="Clipper.App.ClipViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Clip" Height="880" Width="1400" MinHeight="560" MinWidth="1000"
        Icon="pack://application:,,,/Assets/clipper.png"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}"
        WindowStyle="None" ResizeMode="CanResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Grayscale">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TopBar}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Image Source="pack://application:,,,/Assets/clipper.png" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButton}" Content="&#xE921;" Click="Min_Click"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource WindowButton}" Content="&#xE922;" Click="Max_Click"/>
                    <Button Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Video area -->
                <Grid Grid.Column="0" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#000000" CornerRadius="10" ClipToBounds="True">
                        <Grid>
                            <MediaElement x:Name="Player" LoadedBehavior="Manual" ScrubbingEnabled="True" Stretch="Uniform"/>
                            <!-- prev/next -->
                            <Button Style="{StaticResource CaptureBtn}" HorizontalAlignment="Left" VerticalAlignment="Center" Width="48" Height="48" Margin="8,0,0,0"
                                    Command="{Binding PrevCommand}" IsEnabled="{Binding CanPrev}" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Foreground="White" Background="#60000000"/>
                            <Button Style="{StaticResource CaptureBtn}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="48" Height="48" Margin="0,0,8,0"
                                    Command="{Binding NextCommand}" IsEnabled="{Binding CanNext}" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="White" Background="#60000000"/>
                        </Grid>
                    </Border>

                    <!-- Transport -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PlayBtn" Grid.Column="0" Style="{StaticResource CardButton}" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Width="40" Click="PlayPause_Click"/>
                        <Button x:Name="MuteBtn" Grid.Column="1" Style="{StaticResource CardButton}" Content="&#xE74F;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" Click="Mute_Click" ToolTip="Audio"/>
                        <Slider x:Name="PosSlider" Grid.Column="2" Margin="12,0" VerticalAlignment="Center" Minimum="0" ValueChanged="PosSlider_ValueChanged"/>
                        <TextBlock x:Name="TimeText" Grid.Column="3" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" FontSize="12" Text="0:00 / 0:00"/>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource CardButton}" Command="{Binding OpenInEditorCommand}" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Open in Editor" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Use ◄ ► to move between clips" Foreground="{StaticResource TextFaint}" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Details panel -->
                <Border Grid.Column="1" Background="{StaticResource TopBar}" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,18">
                            <StackPanel>
                                <TextBlock Text="Details" Foreground="{StaticResource Text}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                <Border Background="{StaticResource Card}" CornerRadius="8" Padding="12,10">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <TextBox Grid.Row="0" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" MaxLength="280"
                                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}" FontSize="15" TextWrapping="Wrap"
                                                 CaretBrush="{StaticResource Text}" MinHeight="40" AcceptsReturn="False"/>
                                        <TextBlock Grid.Row="1" Text="{Binding Title.Length, StringFormat='{}{0}/280'}" Foreground="{StaticResource TextFaint}" FontSize="11" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding DateText}" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="12"/>
                                    <TextBlock Text="{Binding SizeText}" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text=" • " Foreground="{StaticResource TextFaint}" FontSize="12"/>
                                    <TextBlock Text="{Binding DurationText}" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource FavButton}" Margin="10,0,0,0" ToolTip="Favorite" Command="{Binding ToggleFavoriteCommand}"/>
                                </StackPanel>

                                <TextBlock Text="ALBUMS" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="SemiBold" Margin="0,20,0,8"/>
                                <Button x:Name="AlbumsBtn" Style="{StaticResource CardButton}" Click="Albums_Click" HorizontalAlignment="Left" Padding="12,7">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add or Remove" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="HASHTAGS" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="SemiBold" Margin="0,20,0,8"/>
                                <Button Style="{StaticResource CardButton}" Command="{Binding EditTagsCommand}" HorizontalAlignment="Left" Padding="12,7">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="#" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TagsText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Text="GAME" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="SemiBold" Margin="0,20,0,8"/>
                                <TextBlock Text="{Binding GameText}" Foreground="{StaticResource Text}" FontSize="13"/>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,12">
                            <Grid>
                                <Button HorizontalAlignment="Left" Style="{StaticResource BarButton}" Foreground="{StaticResource Rec}" Command="{Binding DeleteCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button HorizontalAlignment="Right" Style="{StaticResource AccentButton}" Command="{Binding ShareCommand}" Padding="18,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Share" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
