<Window x:Class="Clipper.App.MontageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipper.App"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Montage" Height="680" Width="760" MinHeight="460" MinWidth="560"
        Icon="pack://application:,,,/Assets/clipper.png"
        Background="{StaticResource Bg}" WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize" UseLayoutRounding="True"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal" TextOptions.TextRenderingMode="Grayscale">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:PathToImageConverter x:Key="Thumb"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource TopBar}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Image Source="pack://application:,,,/Assets/clipper.png" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Montage" Foreground="{StaticResource Text}" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowCloseButton}" Content="&#xE8BB;" Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Clip list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Card}" CornerRadius="10" Margin="0,0,0,10" Padding="8" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#xE76F;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextFaint}"
                                                   VerticalAlignment="Center" Margin="4,0,8,0" FontSize="14"/>
                                        <Border Grid.Column="1" Height="90" CornerRadius="6" ClipToBounds="True">
                                            <Grid>
                                                <Rectangle Fill="#08080A"/>
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource Thumb}}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Title}" Foreground="{StaticResource Text}" VerticalAlignment="Center"
                                                   Margin="12,0" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardButton}" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets" ToolTip="Move up"
                                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource CardButton}" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" ToolTip="Move down"
                                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource CardButton}" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Margin="6,0,0,0" ToolTip="Remove"
                                                    Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0"
                                Visibility="{Binding Items.Count, Converter={x:Static local:CountToVisibilityConverter.ZeroVisible}}">
                        <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{StaticResource TextFaint}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add clips to stitch them into one video." Foreground="{StaticResource TextDim}" FontSize="13" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border Grid.Row="2" Background="{StaticResource TopBar}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource CardButton}" Command="{Binding AddClipsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,7,0"/>
                                <TextBlock Text="Add clips"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Style="{StaticResource AccentButton}" Content="Export montage" Padding="20,9"
                            Command="{Binding ExportCommand}" IsEnabled="{Binding Exporting, Converter={x:Static local:InverseBoolConverter.Instance}}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
