[Unit]
Description=Clipper share server
After=network.target

[Service]
Type=simple
# Adjust User and paths to your VPS.
User=clipper
WorkingDirectory=/opt/clipper-share
EnvironmentFile=/opt/clipper-share/.env
ExecStart=/usr/bin/node /opt/clipper-share/server.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
